# Casper Testnet
# NOTE: rpc.testnet.casperlabs.io no longer resolves (dead — casper-js-sdk
# v2.15.4-era default, predates the node.testnet.casper.network naming).
# Use the working node below, which is what production actually runs on.
CASPER_NODE_URL=https://node.testnet.casper.network/rpc
CASPER_CHAIN_NAME=casper-test
CASPER_SECRET_KEY_PATH=./keys/secret_key.pem

# Phoenix Zero oracle (public — no token needed)
ORACLE_FEED_URL=https://rtt.phoenix-ai.work/api/public-feed
ORACLE_HEALTH_URL=https://rtt.phoenix-ai.work/api/health

# Agent config — production runs a 5-minute cycle (300000ms), matching
# every doc in this repo. Keep this in sync with CHECK_INTERVAL_MS elsewhere.
CHECK_INTERVAL_MS=300000
# Address to send test CSPR transfers to (proof of execution) — unused by
# agent.js itself (this var is not currently read anywhere in this agent's
# code), kept here because it's set in the real production .env.
TARGET_ADDRESS=0101010101010101010101010101010101010101010101010101010101010101
# Amount in motes (1 CSPR = 1,000,000,000 motes). Use 2500000000 = 2.5 CSPR
TRANSFER_AMOUNT_MOTES=2500000000

# TESTING_GUIDE.md's dry-run walkthrough assumes this default — keep it true
# so `cp .env.example .env && npm start` is safe without a funded key.
DRY_RUN=true
